<li class="nav-item ${pdict.selectedPayment == 'PAYPAL' ? 'activepaypal' : ''}" data-method-id="${paymentOption.ID}" data-auth="${pdict.paidWithPayPal ? 'no-auth' : 're-auth'}">
    <a class="nav-link paypal-tab ${pdict.selectedPayment == 'PAYPAL' ? 'active' : ''} " data-toggle="tab" href="#paypal-content" role="tab">
        <isif condition="${require('dw/system/Site').getCurrent().getCustomPreferenceValue('CsEnablePayPalV2')}">
            ${Resource.msg('paypal.checkout.label', 'cybersource', 'PayPal Checkout')}
        <iselse/>
            ${paymentOption.name}
        </isif>
    </a>
</li>